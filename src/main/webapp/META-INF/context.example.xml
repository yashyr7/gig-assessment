<Context>
	<Resource
		name="jdbc/GigAssessmentDB"
		auth="Container"
		type="javax.sql.DataSource"
		driverClassName="com.mysql.cj.jdbc.Driver"
		url="jdbc:mysql://YOUR_DB_HOST:3306/gig_assessment?useSSL=false&amp;serverTimezone=UTC"
		username="YOUR_DB_USERNAME"
		password="YOUR_DB_PASSWORD"
		maxActive="20"
		minIdle="2"
		maxIdle="10"
		maxWait="10000" />
</Context>
